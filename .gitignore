# ─── napi-rs build artifacts ─────────────────────────────────────────
# Everything here is regenerated by `npm run prepublishOnly` (which runs
# build:all → napi create-npm-dirs → napi artifacts). Keep these out of
# git: the publish step produces them locally from current source.
index.js
/*.node
/npm


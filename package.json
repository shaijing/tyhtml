{
    "name": "@isomtop/tyhtml",
    "version": "0.1.1",
    "description": "Native Node.js addon (Rust + napi-rs) that compiles Typst .typ files to HTML and extracts metadata via the <meta> label. Includes prebuilt binaries for Windows x64, Linux x64 (glibc), and macOS (Apple Silicon + Intel).",
    "license": "MIT",
    "author": "Ling Yu <yulingsc@outlook.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/shaijing/tyhtml.git"
    },
    "keywords": [
        "napi-rs",
        "native",
        "node-addon",
        "typst",
        "typst-html",
        "html"
    ],
    "main": "index.js",
    "module": "index.js",
    "type": "module",
    "types": "./index.d.ts",
    "engines": {
        "node": ">= 14"
    },
    "packageManager": "bun@1.4.0",
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "index.js",
        "index.d.ts"
    ],
    "optionalDependencies": {
        "@isomtop/tyhtml-win32-x64-msvc": "0.1.1",
        "@isomtop/tyhtml-linux-x64-gnu": "0.1.1",
        "@isomtop/tyhtml-darwin-arm64": "0.1.1",
        "@isomtop/tyhtml-darwin-x64": "0.1.1"
    },
    "napi": {
        "binaryName": "tyhtml",
        "targets": [
            "x86_64-pc-windows-msvc",
            "x86_64-unknown-linux-gnu",
            "aarch64-apple-darwin",
            "x86_64-apple-darwin"
        ]
    },
    "scripts": {
        "build": "napi build --platform --esm --release",
        "build:debug": "napi build --platform --esm",
        "build:win32-x64-msvc": "napi build --platform --esm --release --target x86_64-pc-windows-msvc --cross-compile",
        "build:linux-x64-gnu": "napi build --platform --esm --release --target x86_64-unknown-linux-gnu --cross-compile",
        "build:darwin-arm64": "napi build --platform --esm --release --target aarch64-apple-darwin --cross-compile",
        "build:darwin-x64": "napi build --platform --esm --release --target x86_64-apple-darwin --cross-compile",
        "build:all": "npm run build && npm run build:linux-x64-gnu && npm run build:darwin-arm64 && npm run build:darwin-x64",
        "create-npm-dirs": "napi create-npm-dirs",
        "artifacts": "napi artifacts --output-dir .",
        "prepublishOnly": "npm run create-npm-dirs && npm run artifacts"
    },
    "devDependencies": {
        "@napi-rs/cross-toolchain": "^1.0.0",
        "@types/bun": "latest",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@napi-rs/cli": "^3.7.2"
    }
}